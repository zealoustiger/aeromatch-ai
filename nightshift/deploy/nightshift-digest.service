# /etc/systemd/system/nightshift-digest.service
# Generates the morning overnight-review digest and publishes it to the admin Daily Report.
[Unit]
Description=ClubHanger Night Shift morning digest
After=docker.service
Requires=docker.service

[Service]
Type=oneshot
TimeoutStartSec=900
ExecStart=/usr/bin/docker run --rm \
  --name clubhanger-nightshift-digest \
  --memory=2g --cpus=1 \
  -e NS_STATE_DIR=/home/night/state \
  -e TZ=America/Los_Angeles \
  -v /opt/nightshift/repo:/app \
  -v /opt/nightshift/claude:/home/night/.claude \
  -v /opt/nightshift/state:/home/night/state \
  -v /opt/nightshift/ssh:/home/night/.ssh:ro \
  --entrypoint /app/nightshift/bin/run-digest.sh \
  clubhanger-nightshift:latest

[Install]
WantedBy=multi-user.target
