# /etc/systemd/system/nightshift-harvest.service
# Recovers photos for hidden hangar67 listings via Bright Data Web Unlocker.
[Unit]
Description=ClubHanger Night Shift hangar67 photo harvest
After=docker.service
Requires=docker.service

[Service]
Type=oneshot
TimeoutStartSec=7200
ExecStart=/usr/bin/docker run --rm \
  --name clubhanger-nightshift-harvest \
  --memory=1g --cpus=1 \
  -e NS_STATE_DIR=/home/night/state \
  -e TZ=America/Los_Angeles \
  -v /opt/nightshift/repo:/app \
  -v /opt/nightshift/claude:/home/night/.claude \
  -v /opt/nightshift/state:/home/night/state \
  -v /opt/nightshift/ssh:/home/night/.ssh:ro \
  --entrypoint /app/nightshift/bin/run-harvest.sh \
  clubhanger-nightshift:latest

[Install]
WantedBy=multi-user.target
