# Night Shift drain runner — see nightshift/VPS_RUNBOOK.md
# Debian base so Playwright's Chromium system libs install cleanly.
# Tooling lives in the image; code + secrets + creds are mounted at runtime.
FROM node:22-bookworm

RUN apt-get update && apt-get install -y --no-install-recommends \
      git ca-certificates jq tini \
      fonts-liberation fonts-noto-color-emoji \
      libnss3 libatk1.0-0 libatk-bridge2.0-0 libcups2 libdrm2 libxkbcommon0 \
      libxcomposite1 libxdamage1 libxfixes3 libxrandr2 libgbm1 libasound2 \
    && rm -rf /var/lib/apt/lists/*

# Claude Code CLI (subscription auth, NOT an API key)
RUN npm install -g @anthropic-ai/claude-code

# Playwright (global, importable via NODE_PATH) + Chromium for the QA smoke test
# (nightshift/bin/qa-smoke.mjs). Browsers install to a world-readable path so the
# non-root `night` user can launch them.
ENV PLAYWRIGHT_BROWSERS_PATH=/ms-playwright
ENV NODE_PATH=/usr/local/lib/node_modules
RUN npm install -g playwright \
    && playwright install --with-deps chromium \
    && chmod -R a+rX /ms-playwright

RUN useradd -m -u 10001 night
WORKDIR /app
USER night

# tini so SIGINT/SIGTERM (from `timeout` / systemd) reaches claude cleanly.
ENTRYPOINT ["/usr/bin/tini", "--", "/app/nightshift/bin/run-drain.sh"]
